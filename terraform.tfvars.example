# --- CONFIGURAÇÕES GERAIS ---
aws_region   = "us-east-1"
project_name = "camplog"
environment  = "prod" # dev, staging, prod

# --- CONFIGURAÇÕES DO POSTGRES RDS ---
db_instance_class    = "db.t4g.micro"
db_name              = "camplog"
db_username          = "camplog_admin"
db_password          = "TroquePorUmaSenhaMuitoForte123!" # Sensitive
db_allocated_storage = 20

# VPC opcional para banco isolado (caso aplicável)
# db_subnet_group_name   = "subnet-group-camplog"
# vpc_security_group_ids = ["sg-0123456789abcdef0"]

# --- VARIÁVEIS SEGURAS / SECRETS ---
google_client_id      = "123456789-googleclientid123.apps.googleusercontent.com"
google_client_secret  = "GOCSPX-googleclientsecret123456" # Sensitive
github_client_id      = "Iv1.githubclientid123"
github_client_secret  = "githubclientsecret1234567890abcdef" # Sensitive
email_service_api_key = "re_emailapikeyresend12345" # Sensitive
jwt_secret_key        = "jwtkeysecretdatabasefortecamplogauthsigning12345" # Sensitive
data_platform_secret  = "camp-log-data-sec-123" # Sensitive
